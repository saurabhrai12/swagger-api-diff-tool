# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env
.conda/

# Streamlit
.streamlit/secrets.toml

# Secrets / credentials — NEVER commit tokens or keys
*.token
*.secret
secrets.json
credentials.json
.secrets/

# Spec files (may contain internal API details — add back selectively)
specs/*.json
specs/*.yaml
specs/*.yml

# Snapshots (auto-generated runtime data)
snapshots/

# Sample data (may contain real request payloads)
# samples/samples.json   # Uncomment to also exclude samples

# Uploaded Excel files (may contain tokens/credentials)
*.xlsx
*.xls
*.csv

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Logs
*.log
